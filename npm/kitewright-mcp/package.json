    "@kitewright/mcp-darwin-x64": "0.1.0",
    "@kitewright/mcp-linux-x64-gnu": "0.1.0",
    "@kitewright/mcp-win32-x64-msvc": "0.1.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
