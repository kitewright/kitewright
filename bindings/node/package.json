{
  "name": "@kitewright/node",
  "version": "0.1.0",
  "description": "Puppeteer-compatible (experimental) HTML→PDF / browser automation backed by the Rust kitewright-engine via napi-rs",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "napi": {
    "name": "kitewright-node",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "binding.js",
    "binding.d.ts",
    "*.node"
  ],
  "optionalDependencies": {
    "@kitewright/node-darwin-arm64": "0.1.0",
    "@kitewright/node-darwin-x64": "0.1.0",
    "@kitewright/node-linux-x64-gnu": "0.1.0",
    "@kitewright/node-win32-x64-msvc": "0.1.0"
  },
  "scripts": {
    "build": "napi build --release --js binding.js --dts binding.d.ts",
    "build:debug": "napi build --js binding.js --dts binding.d.ts",
    "test": "node --test test/"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  }
}
